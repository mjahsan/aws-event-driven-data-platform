{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "DatabricksAWSConnection",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject",
                "s3:ListBucket",
                "s3:GetBucketLocation",
                "s3:ListMultiPartUploadParts"
            ],
            "Resource": [
                "arn:aws:s3:::event-platform-new",
                "arn:aws:s3:::event-platform-new/*"
            ]
        }
    ]
}