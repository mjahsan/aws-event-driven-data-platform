{
  "Comment": "Spark job transformation orchestration for Silver to Gold",
  "StartAt": "ReceiveMessages",
  "States": {
    "ReceiveMessages": {
      "Type": "Task",
      "Resource": "arn:aws:states:::aws-sdk:sqs:receiveMessage",
      "Parameters": {
        "QueueUrl": "https://sqs.<REGION>.amazonaws.com/<ACCOUNT NUMBER>/processing-event-platform-new",
        "MaxNumberOfMessages": 10,
        "WaitTimeSeconds": 5
      },
      "Retry": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "IntervalSeconds": 2,
          "MaxAttempts": 5,
          "BackoffRate": 2
        }
      ],
      "ResultPath": "$.sqs",
      "Next": "CheckIfEmpty"
    },
    "CheckIfEmpty": {
      "Type": "Choice",
      "Choices": [
        {
          "Variable": "$.sqs.Messages",
          "IsPresent": true,
          "Next": "PrepareMetadata"
        },
        {
          "Variable": "$.sqs.Messages",
          "IsPresent": false,
          "Next": "Finish"
        }
      ]
    },
    "PrepareMetadata": {
      "Type": "Map",
      "ItemsPath": "$.sqs.Messages",
      "ResultPath": "$.fileMetadata",
      "Iterator": {
        "StartAt": "DecodeBody",
        "States":{
          "DecodeBody":{
            "Type": "Pass",
            "Parameters": {
              "Body.$": "States.StringToJson($.Body)"
            },
            "ResultPath": "$.decoded",
            "Next": "ExtractFields"
          },
          "ExtractFields": {
            "Type": "Pass",
            "Parameters": {
              "filepath.$": "$.decoded.body.file_path",
              "etag.$": "$.decoded.body.etag"
            },
            "End": true
          }
        }
      },
      "Next": "ProgressUpdateInDynamoDB"
    },
    "ProgressUpdateInDynamoDB":{
      "Type": "Map",
      "ItemsPath": "$.fileMetadata",
      "ResultPath": null,
      "Next": "TriggerDatabricksJob",
      "Iterator": {
        "StartAt": "ChangeStatus",
        "States": {
          "ChangeStatus": {
            "Type": "Task",
            "Resource": "arn:aws:states:::aws-sdk:dynamodb:updateItem",
            "Parameters": {
              "TableName": "event-platform-metadata",
              "Key": {
                "etag": {
                  "S.$": "$.etag"
                }
              },
              "UpdateExpression": "Set #status = :newStatus",
              "ConditionExpression": "#status = :expected",
              "ExpressionAttributeNames": {
                "#status": "status"
              },
              "ExpressionAttributeValues": {
                ":newStatus": {
                  "S": "IN_PROGRESS(SILVER)"
                },
                ":expected": {
                  "S": "VALIDATED"
                }
              }
            },
            "Retry": [
              {
                "ErrorEquals": [
                  "DynamoDB.ProvisionedThroughputExceededException",
                  "States.Timeout",
                  "States.TaskFailed"
                ],
                "IntervalSeconds": 2,
                "MaxAttempts": 3,
                "BackoffRate": 2
              }
            ],
            "Catch": [
              {
                "ErrorEquals": [
                  "DynamoDB.ConditionalCheckFailedException"
                ],
                "Next": "AlreadyUpdated"
              }
            ],
            "ResultPath": null,
            "End": true
          },
          "AlreadyUpdated": {
            "Type": "Pass",
            "End": true
          }
        }
      }
    },
    "TriggerDatabricksJob": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": {
        "FunctionName": "databricks-trigger-lambda",
        "Payload.$": "$.fileMetadata"
      },
      "ResultPath": "$.triggerResult",
      "Next": "WaitforStatusCheck",
      "Catch": [
        {
        "ErrorEquals":[
          "States.ALL"
        ],
        "Next": "RevertingDynamoDBStatus"
        }
      ]
    },
    "RevertingDynamoDBStatus":{
      "Type": "Map",
      "ItemsPath": "$.fileMetadata",
      "ResultPath": null,
      "Next": "TriggerAnotherDatabricksJob",
      "Iterator": {
        "StartAt": "RevertStatus",
        "States": {
          "RevertStatus": {
            "Type": "Task",
            "Resource": "arn:aws:states:::aws-sdk:dynamodb:updateItem",
            "Parameters": {
              "TableName": "event-platform-metadata",
              "Key": {
                "etag": {
                  "S.$": "$.etag"
                }
              },
              "UpdateExpression": "Set #status = :newStatus",
              "ConditionExpression": "#status = :expected",
              "ExpressionAttributeNames": {
                "#status": "status"
              },
              "ExpressionAttributeValues": {
                ":newStatus": {
                  "S": "VALIDATED"
                },
                ":expected": {
                  "S": "IN_PROGRESS(SILVER)"
                }
              }
            },
            "Retry": [
              {
                "ErrorEquals": [
                  "DynamoDB.ProvisionedThroughputExceededException",
                  "States.Timeout",
                  "States.TaskFailed"
                ],
                "IntervalSeconds": 2,
                "MaxAttempts": 3,
                "BackoffRate": 2
              }
            ],
            "Catch": [
              {
                "ErrorEquals": [
                  "DynamoDB.ConditionalCheckFailedException"
                ],
                "Next": "AlreadyUpdated"
              }
            ],
            "ResultPath": null,
            "End": true
          },
          "AlreadyUpdated": {
            "Type": "Pass",
            "End": true
          }
        }
      }
    },
    "TriggerAnotherDatabricksJob":{
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": {
        "FunctionName": "databricks-trigger-lambda",
        "Payload.$": "$.fileMetadata"
      },
      "ResultPath": "$.triggerResult",
      "Next": "WaitforStatusCheck",
      "Retry": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "MaxAttempts": 3,
          "IntervalSeconds": 5,
          "BackoffRate": 2
        }
      ],
      "Catch": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "Next": "PrepareDeleteEntriesForFailedTasks"
        }
      ]
    },
    "WaitforStatusCheck": {
      "Type": "Wait",
      "Seconds": 60,
      "Next": "CheckDatabricksStatus"
    },
    "CheckDatabricksStatus": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": {
        "FunctionName": "databricks-status-lambda",
        "Payload": {
          "run_id.$": "$.triggerResult.Payload.run_id"
        }
      },
      "ResultPath": "$.statusResult",
      "Next": "JobStatusDecision"
    },
    "JobStatusDecision": {
      "Type": "Choice",
      "Choices": [
        {
          "Variable": "$.statusResult.Payload.overallstatus",
          "StringEquals": "RUNNING",
          "Next": "WaitforStatusCheck"
        },
        {
          "Variable": "$.statusResult.Payload.overallstatus",
          "StringEquals": "SUCCESS",
          "Next": "UpdateFinalDynamoDBStatus"
        },
        {
          "Variable": "$.statusResult.Payload.overallstatus",
          "StringEquals": "FAILED",
          "Next": "RevertingDynamoDBStatus"
        }
      ]
    },
    "UpdateFinalDynamoDBStatus": {
      "Type": "Map",
      "ItemsPath": "$.statusResult.Payload.fileResults",
      "ResultPath": null,
      "Next": "PrepareDeleteEntries",
      "Iterator": {
        "StartAt": "ChangeStatus",
        "States": {
          "ChangeStatus": {
            "Type": "Task",
            "Resource": "arn:aws:states:::aws-sdk:dynamodb:updateItem",
            "Parameters": {
              "TableName": "event-platform-metadata",
              "Key": {
                "etag": {
                  "S.$": "$.etag"
                }
              },
              "UpdateExpression": "Set #status = :newStatus, run_id = :rid",
              "ConditionExpression": "#status = :expected",
              "ExpressionAttributeNames": {
                "#status": "status"
              },
              "ExpressionAttributeValues": {
                ":newStatus": {
                    "S.$": "$.status"
                },
                ":rid": {
                  "S.$": "$.run_id"
                },
                ":expected": {
                  "S": "IN_PROGRESS(SILVER)"
                }
              }
            },
            "Retry": [
              {
                "ErrorEquals": [
                  "DynamoDB.ProvisionedThroughputExceededException",
                  "States.Timeout",
                  "States.TaskFailed"
                ],
                "IntervalSeconds": 2,
                "MaxAttempts": 3,
                "BackoffRate": 2
              }
            ],
            "Catch": [
              {
                "ErrorEquals": [
                  "DynamoDB.ConditionalCheckFailedException"
                ],
                "Next": "AlreadyUpdated"
              }
            ],
            "ResultPath": null,
            "End": true
          },
          "AlreadyUpdated": {
            "Type": "Pass",
            "End": true
          }
        }
      }
    },
    "PrepareDeleteEntries": {
      "Type": "Map",
      "ItemsPath": "$.sqs.Messages",
      "ResultPath": "$.deleteEntries",
      "Next": "DeleteMessages",
      "Iterator": {
        "StartAt": "FormatDeleteEntry",
        "States": {
          "FormatDeleteEntry": {
            "Type": "Pass",
            "Parameters": {
              "Id.$": "$.MessageId",
              "ReceiptHandle.$": "$.ReceiptHandle"
            },
            "End": true
          }
        }
      }
    },
    "DeleteMessages": {
      "Type": "Task",
      "Resource": "arn:aws:states:::aws-sdk:sqs:deleteMessageBatch",
      "Parameters": {
        "QueueUrl": "https://sqs.<REGION>.amazonaws.com/<ACCOUNT NUMBER>/processing-event-platform-new",
        "Entries.$": "$.deleteEntries"
      },
      "Retry": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "IntervalSeconds": 2,
          "MaxAttempts": 3,
          "BackoffRate": 3
        }
      ],
      "End": true
    },
    "PrepareDeleteEntriesForFailedTasks": {
      "Type": "Map",
      "ItemsPath": "$.sqs.Messages",
      "ResultPath": "$.deleteEntries",
      "Next": "DeleteMessagesForFailsTasks",
      "Iterator": {
        "StartAt": "FormatDeleteEntry",
        "States": {
          "FormatDeleteEntry": {
            "Type": "Pass",
            "Parameters": {
              "Id.$": "$.MessageId",
              "ReceiptHandle.$": "$.ReceiptHandle"
            },
            "End": true
          }
        }
      }
    },
    "DeleteMessagesForFailsTasks": {
      "Type": "Task",
      "Resource": "arn:aws:states:::aws-sdk:sqs:deleteMessageBatch",
      "Parameters": {
        "QueueUrl": "https://sqs.<REGION>.amazonaws.com/<ACCOUNT NUMBER>/processing-event-platform-new",
        "Entries.$": "$.deleteEntries"
      },
      "Retry": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "IntervalSeconds": 2,
          "MaxAttempts": 3,
          "BackoffRate": 3
        }
      ],
      "Next": "FailState"
    },
    "FailState": {
      "Type": "Fail",
      "Error": "DatabricksFailure",
      "Cause": "Databricks job failed"
    },
    "Finish": {
      "Type": "Succeed"
    }
  }
}