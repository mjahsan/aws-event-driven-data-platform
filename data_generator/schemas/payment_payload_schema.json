{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Payment Event Payload",
  "type": "object",
  "required": ["payment_id", "order_id"],
  "properties": {
    "payment_id": {
      "type": "string"
    },
    "order_id": {
      "type": "string"
    },
    "amount": {
      "type": "number",
      "minimum": 0
    },
    "currency": {
      "type": "string"
    },
    "status": {
      "type": "string"
    }
  },
  "additionalProperties": false
}

