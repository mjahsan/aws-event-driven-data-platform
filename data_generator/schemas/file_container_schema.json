{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Event File Container",
	"type": "object",
	"required": ["file_id", "domain", "source_system", "created_at", "events"],
	"properties": {
		"file_id": {
			"type": "string"
		},
		"domain": {
			"type": "string"
			"enum": ["user_events", "order_events", "payment_events"]
		},
		"source_system": {
			"type": "string"
		},
		"created_at": {
			"type": "string",
			"format": "date-time"
		},
		"events": {
			"type": "array",
			"minItems": 1
		}
	},
	"additionalProperties": false
}