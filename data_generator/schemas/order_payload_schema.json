{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Order Event Payload",
  "type": "object",
  "required": ["order_id", "user_id"],
  "properties": {
    "order_id": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "amount": {
      "type": "number",
      "minimum": 0
    },
    "currency": {
      "type": "string"
    },
    "status": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
